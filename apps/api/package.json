{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @repo/shared build && nest start --watch",
    "build": "pnpm --filter @repo/shared build && nest build",
    "start": "pnpm --filter @repo/shared build && node dist/main.js",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "express": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@vercel/node": "^5.3.24",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2"
  }
}
