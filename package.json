{
  "name": "y",
  "private": true,
  "scripts": {
    "build": "turbo run build --cache-dir=.turbo-cache",
    "dev": "turbo run dev --cache-dir=.turbo-cache",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types --cache-dir=.turbo-cache"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
